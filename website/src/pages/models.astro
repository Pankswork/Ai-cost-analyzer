---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { categories, slugify } from '../data/tools';

interface ModelGroup {
  model: string;
  tools: { name: string; slug: string; category: string; categoryId: string; categoryIcon: string; bestFor: string }[];
}

const modelMap = new Map<string, ModelGroup>();

for (const cat of categories) {
  for (const tool of cat.tools) {
    if (tool.models && tool.models.length > 0) {
      for (const model of tool.models) {
        if (!modelMap.has(model)) {
          modelMap.set(model, { model, tools: [] });
        }
        modelMap.get(model)!.tools.push({
          name: tool.name,
          slug: `${cat.id}-${slugify(tool.name)}`,
          category: cat.title,
          categoryId: cat.id,
          categoryIcon: cat.icon,
          bestFor: tool.bestFor,
        });
      }
    }
  }
}

const modelGroups = Array.from(modelMap.values()).sort((a, b) => a.model.localeCompare(b.model));
const totalToolsWithModels = modelGroups.reduce((sum, g) => sum + g.tools.length, 0);
const siteUrl = 'https://bestfreeaifor.com';
const modelBreadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'AI Models', url: `${siteUrl}/models/` },
];
---

<Layout title="AI Models Directory (2026) — Best Free AI For" description="Browse all AI tools for 2026 grouped by the model they use. Compare tools powered by GPT-4o, Claude, Gemini, DALL-E 3, Imagen 3, and more." canonicalUrl={`${siteUrl}/models/`} keywords="ai models directory 2026, gpt models free, claude models free, gemini models free, ai tools by model, compare ai models, free ai model comparison, best ai models 2026" breadcrumbs={modelBreadcrumbs}>
  <Navbar />

  <main class="min-h-screen">
    <div class="container-main py-12">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-body-sm text-mute mb-8">
        <a href="/" class="no-underline text-mute hover:text-ink transition-colors">Home</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-ink">AI Models</span>
      </nav>

      <!-- Header -->
      <div class="text-center mb-12">
        <span class="text-caption-mono text-mute block mb-3">MODELS DIRECTORY</span>
        <h1 class="text-display-xl text-ink mb-4 text-balance">AI Models</h1>
        <p class="text-body-lg text-body mx-auto text-balance">
          {modelGroups.length} models powering {totalToolsWithModels} tools — browse by AI model to find every tool using it.
        </p>
      </div>

      <!-- Models Index -->
      <div class="flex flex-wrap justify-center gap-2 mb-12 pb-8 border-b border-hairline">
        {modelGroups.map((g) => (
          <a href={`#${g.model.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '')}`} class="px-3 py-1.5 rounded-full text-caption-mono text-body bg-canvas border border-hairline no-underline hover:border-ink hover:text-ink transition-colors">
            {g.model} ({g.tools.length})
          </a>
        ))}
      </div>

      <!-- Model Groups -->
      <div class="space-y-10">
        {modelGroups.map((group) => {
          const modelId = group.model.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '');
          return (
            <section id={modelId}>
              <div class="flex items-center gap-3 mb-4">
                <span class="w-8 h-8 rounded-lg bg-ink text-white dark:text-canvas text-body-sm font-bold flex items-center justify-center">{group.tools.length}</span>
                <h2 class="text-display-lg text-ink">{group.model}</h2>
              </div>
              <p class="text-body-md text-body mb-6">Used by {group.tools.length} tool{group.tools.length > 1 ? 's' : ''} across {new Set(group.tools.map(t => t.category)).size} categor{new Set(group.tools.map(t => t.category)).size > 1 ? 'ies' : 'y'}</p>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
                {group.tools.map((t) => (
                  <a
                    href={`/tool/${t.slug}`}
                    class="bg-canvas rounded-lg border border-hairline p-4 no-underline hover:shadow-card-hover transition-shadow duration-200 block"
                  >
                    <div class="flex items-center gap-2 mb-2">
                      <span class="text-sm">{t.categoryIcon}</span>
                      <span class="text-caption-mono text-mute">{t.category}</span>
                    </div>
                    <h3 class="text-display-sm text-ink mb-1">{t.name}</h3>
                    <p class="text-body-sm text-body line-clamp-2">{t.bestFor}</p>
                  </a>
                ))}
              </div>
            </section>
          );
        })}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
