---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ToolCard from '../../components/ToolCard.astro';
import FAQSection from '../../components/FAQSection.astro';
import Footer from '../../components/Footer.astro';
import { categories, slugify } from '../../data/tools';

const siteUrl = 'https://bestfreeaifor.com';

export async function getStaticPaths() {
  return categories.map((cat) => ({
    params: { id: cat.id },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const pageTitle = `Best Free AI For ${category.title} (2026) — Top Free ${category.title} Tools`;
const pageDescription = `${category.description} Discover the best free ${category.title.toLowerCase()} AI tools for 2026 ranked by quality, features, and value.`;
const catLower = category.title.toLowerCase();
const topTools = category.tools.slice(0, 3).map(t => t.name).join(', ');
const pageKeywords = `best free ai for ${catLower}, best free ${catLower} ai tools 2026, free ${catLower} ai tools, best ${catLower} ai, free ai ${catLower}, ${catLower} ai tools 2026, top free ${catLower} tools, ${topTools}`;
const catBreadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Categories', url: `${siteUrl}/#categories` },
  { name: category.title, url: `${siteUrl}/category/${category.id}/` },
];
const relatedCategories = categories.filter(c => c.id !== category.id).slice(0, 6);
---

<Layout title={pageTitle} description={pageDescription} canonicalUrl={`${siteUrl}/category/${category.id}/`} keywords={pageKeywords} breadcrumbs={catBreadcrumbs}>
  <Navbar />

  <main class="min-h-screen">
    <div class="container-main py-12">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-body-sm text-mute mb-8">
        <a href="/" class="no-underline text-mute hover:text-ink transition-colors">Home</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/#categories" class="no-underline text-mute hover:text-ink transition-colors">Categories</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-ink">{category.icon} {category.title}</span>
      </nav>

      <!-- Category Header -->
      <div class="text-center mb-12">
        <span class="text-4xl block mb-4">{category.icon}</span>
        <span class="text-caption-mono text-mute block mb-3">{category.title.toUpperCase()}</span>
        <h1 class="text-display-xl text-ink mb-4 text-balance">Best Free AI For {category.title} (2026)</h1>
        <p class="text-body-lg text-body mx-auto text-balance">
          {category.description}
        </p>
      </div>

      <!-- Tools Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {category.tools.map((tool, idx) => (
          <ToolCard tool={tool} rank={idx + 1} slug={`${category.id}-${slugify(tool.name)}`} />
        ))}
      </div>

      <!-- Related Categories -->
      <div class="mt-16 mb-8">
        <span class="text-caption-mono text-mute block mb-4 text-center">RELATED CATEGORIES</span>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2">
          {relatedCategories.map(cat => (
            <a
              href={`/category/${cat.id}`}
              class="flex flex-col items-center gap-1.5 bg-canvas border border-hairline rounded-lg p-4 no-underline hover:shadow-card-hover transition-shadow duration-200 text-center"
            >
              <span class="text-2xl">{cat.icon}</span>
              <span class="text-body-sm text-ink font-medium">{cat.title}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center mt-16 py-8 border-t border-hairline">
        <p class="text-body-md text-body mb-4">Explore more AI categories</p>
        <a
          href="/#categories"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-pill-sm text-body-md text-white dark:text-canvas bg-ink no-underline hover:opacity-90 transition-opacity"
        >
          Browse All Categories
        </a>
      </div>
    </div>
  </main>

  <FAQSection categoryId={category.id} />

  <Footer />
</Layout>
