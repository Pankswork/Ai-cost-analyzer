---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const siteUrl = 'https://bestfreeaifor.com';
const rareBreadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Rare Tier', url: `${siteUrl}/offers/rare/` },
];
---

<Layout title="Rare Tier — Exclusive Offers | Best Free AI For" description="Start with the Rare tier — standard AI tools, community support, and basic analytics at no cost." canonicalUrl={`${siteUrl}/offers/rare/`} keywords="rare tier ai, standard ai tools, free ai tools tier, ai community support, ai analytics free" breadcrumbs={rareBreadcrumbs}>
  <Navbar />

  <main class="min-h-screen">
    <div class="container-main py-12">
      <nav class="flex items-center gap-2 text-body-sm text-mute mb-8">
        <a href="/" class="no-underline text-mute hover:text-ink transition-colors">Home</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-ink">Rare</span>
      </nav>

      <div class="relative rounded-2xl p-[6px] overflow-hidden shine-border">
        <div class="shine-overlay"></div>
        <div class="relative rounded-2xl purple-card p-12 md:p-20 text-center">
          <div class="relative z-10">
            <span class="text-caption-mono text-black block mb-4">EXCLUSIVE OFFER</span>
            <h1 class="text-display-xl text-black mb-4 drop-shadow-lg">Rare Tier</h1>
            <p class="text-body-lg text-black mb-8 drop-shadow">
              There's no offers right now.
            </p>
            <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-pill-sm text-body-md font-semibold text-white bg-black/40 hover:bg-black/60 backdrop-blur-sm no-underline transition-all">
              Have an offer? Visit here for details →
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .purple-card {
    background: linear-gradient(to right,
      #e9d5ff 0%, #e9d5ff 20%,
      #d8b4fe 20%, #d8b4fe 40%,
      #a855f7 40%, #a855f7 60%,
      #7c3aed 60%, #7c3aed 80%,
      #581c87 80%, #581c87 100%
    );
  }

  .shine-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 0%,
      transparent 25%,
      rgba(192, 192, 192, 0.2) 35%,
      rgba(220, 220, 220, 0.45) 42%,
      rgba(240, 240, 240, 0.55) 48%,
      rgba(255, 255, 255, 0.6) 50%,
      rgba(240, 240, 240, 0.55) 52%,
      rgba(220, 220, 220, 0.45) 58%,
      rgba(192, 192, 192, 0.2) 65%,
      transparent 75%,
      transparent 100%
    );
    background-size: 400% 100%;
    animation: shineSweep 3s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
    border-radius: inherit;
  }

  @keyframes shineSweep {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .shine-border {
    box-shadow: 0 0 0 4px #a0a0a0;
  }
</style>
