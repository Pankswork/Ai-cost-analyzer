---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const siteUrl = 'https://bestfreeaifor.com';
const email = 'devpanks@gmail.com';
const termsBreadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Terms & Conditions', url: `${siteUrl}/terms/` },
];
---

<Layout
  title="Terms & Conditions — BestFreeAIFor"
  description="Terms and Conditions for BestFreeAIFor.com. Read the terms governing your use of our AI tool comparison website."
  canonicalUrl={`${siteUrl}/terms/`}
  keywords="best free ai for terms, bestfreeaifor terms, ai tool directory terms of service"
  breadcrumbs={termsBreadcrumbs}
>
  <Navbar />

  <main class="min-h-screen">
    <div class="container-main py-12">
      <nav class="flex items-center gap-2 text-body-sm text-mute mb-8">
        <a href="/" class="no-underline text-mute hover:text-ink transition-colors">Home</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-ink">Terms & Conditions</span>
      </nav>

      <div class="text-center mb-12">
          <span class="text-caption-mono text-mute block mb-3">LEGAL</span>
          <h1 class="text-display-xl text-ink mb-4">Terms & Conditions</h1>
          <p class="text-body-md text-mute">Last updated: June 2026</p>
        </div>

        <div class="space-y-8 text-body-md text-body leading-relaxed">
          <section>
            <h2 class="text-display-sm text-ink mb-3">1. Acceptance of Terms</h2>
            <p>By accessing or using BestFreeAIFor.com ("the Website"), you agree to be bound by these Terms & Conditions. If you do not agree with any part of these terms, you must not use our website.</p>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">2. Description of Service</h2>
            <p>BestFreeAIFor.com is an AI tool directory and comparison website. We provide information, reviews, and comparisons of AI tools that offer free tiers. We do not host, operate, or provide any of the AI tools listed on our site. All tools are third-party services accessed through their respective websites.</p>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">3. No Warranty</h2>
            <p>The information on this website is provided "as is" without any warranty of any kind. We strive for accuracy but cannot guarantee that all information about free tiers, pricing, features, or availability is always current. AI tool providers change their offerings frequently, and we recommend verifying details on the tool's official website before relying on any information.</p>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">4. Affiliate Disclosure</h2>
            <p>BestFreeAIFor.com may include affiliate links for some of the AI tools we review. If you click through and make a purchase, we may earn a small commission at no extra cost to you. Our reviews and rankings remain honest and unbiased — we only recommend tools we genuinely believe in, regardless of affiliate relationships.</p>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">5. Intellectual Property</h2>
            <p>All content on this website, including text, graphics, logos, and comparisons, is the property of BestFreeAIFor.com unless otherwise attributed. You may not reproduce, distribute, or modify our content without prior written permission.</p>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">6. Third-Party Links</h2>
            <p>Our website contains links to third-party websites and AI tools. We are not responsible for the content, privacy practices, or terms of these external sites. Accessing third-party links from our site is at your own risk.</p>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">7. Limitation of Liability</h2>
            <p>BestFreeAIFor.com shall not be liable for any damages arising from your use of the website or reliance on any information provided. We are not responsible for any issues, data loss, or costs incurred from using third-party AI tools discovered through our site.</p>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">8. User Conduct</h2>
            <p class="mb-3">You agree to use the Website only for lawful purposes. You must not:</p>
            <ul class="list-disc pl-6 space-y-1">
              <li>Scrape, mine, or systematically extract content without permission</li>
              <li>Use the site for any fraudulent or malicious purposes</li>
              <li>Attempt to disrupt or compromise the website's operation</li>
            </ul>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">9. Changes to Terms</h2>
            <p>We reserve the right to modify these terms at any time. Changes will be effective immediately upon posting. Your continued use of the website after changes constitutes acceptance of the new terms.</p>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">10. Contact</h2>
            <p>For questions about these Terms & Conditions, <a href={`mailto:${email}`} class="text-link underline">Email Me</a>.</p>
          </section>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
