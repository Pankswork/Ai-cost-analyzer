---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const siteUrl = 'https://bestfreeaifor.com';
const email = 'devpanks@gmail.com';
const privacyBreadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Privacy Policy', url: `${siteUrl}/privacy/` },
];
---

<Layout
  title="Privacy Policy — BestFreeAIFor"
  description="Privacy Policy for BestFreeAIFor.com. Learn how we collect, use, and protect your information when you use our AI tool directory."
  canonicalUrl={`${siteUrl}/privacy/`}
  keywords="best free ai for privacy, bestfreeaifor privacy, ai tool directory privacy policy"
  breadcrumbs={privacyBreadcrumbs}
>
  <Navbar />

  <main class="min-h-screen">
    <div class="container-main py-12">
      <nav class="flex items-center gap-2 text-body-sm text-mute mb-8">
        <a href="/" class="no-underline text-mute hover:text-ink transition-colors">Home</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-ink">Privacy Policy</span>
      </nav>

      <div class="text-center mb-12">
          <span class="text-caption-mono text-mute block mb-3">LEGAL</span>
          <h1 class="text-display-xl text-ink mb-4">Privacy Policy</h1>
          <p class="text-body-md text-mute">Last updated: June 2026</p>
        </div>

        <div class="space-y-8 text-body-md text-body leading-relaxed">
          <section>
            <h2 class="text-display-sm text-ink mb-3">1. Introduction</h2>
            <p>BestFreeAIFor.com ("we," "our," or "us") is committed to protecting your privacy. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website.</p>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">2. Information We Collect</h2>
            <p class="mb-3">We collect minimal information to provide and improve our service:</p>
            <ul class="list-disc pl-6 space-y-2">
              <li><strong>Usage Data:</strong> Anonymous analytics about page visits, clicks, and browsing patterns on our site.</li>
              <li><strong>Cookies:</strong> We use minimal cookies for dark mode preference storage and basic analytics. No tracking or advertising cookies are used.</li>
              <li><strong>Contact Information:</strong> If you contact us via email, we collect your email address and any information you voluntarily provide.</li>
            </ul>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">3. How We Use Your Information</h2>
            <p class="mb-3">We use the collected information for:</p>
            <ul class="list-disc pl-6 space-y-2">
              <li>Operating and maintaining our website</li>
              <li>Improving user experience and content</li>
              <li>Responding to your inquiries and support requests</li>
              <li>Analyzing usage trends to improve our AI tool directory</li>
            </ul>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">4. Third-Party Links</h2>
            <p>Our website contains links to third-party AI tools and websites. We are not responsible for the privacy practices of these external sites. We encourage you to review their privacy policies before providing any personal information.</p>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">5. Data Security</h2>
            <p>We implement reasonable security measures to protect your information. However, no method of transmission over the Internet is 100% secure. We do not store sensitive personal data on our servers.</p>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">6. Your Rights</h2>
            <p class="mb-3">Depending on your location, you may have the right to:</p>
            <ul class="list-disc pl-6 space-y-2">
              <li>Access personal data we hold about you</li>
              <li>Request correction or deletion of your data</li>
              <li>Opt out of analytics tracking</li>
              <li>Withdraw consent where applicable</li>
            </ul>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">7. Changes to This Policy</h2>
            <p>We may update this Privacy Policy from time to time. Changes will be posted on this page with an updated revision date. We encourage you to review this policy periodically.</p>
          </section>

          <section>
            <h2 class="text-display-sm text-ink mb-3">8. Contact Us</h2>
            <p>If you have questions about this Privacy Policy, please <a href={`mailto:${email}`} class="text-link underline">Email Me</a>.</p>
          </section>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
