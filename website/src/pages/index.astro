          <span class="text-body-md text-mute">Categories</span>
        </div>
        <div class="flex items-baseline gap-1.5">
          <span class="text-display-xl text-ink">{allCategories.reduce((acc, cat) => acc + cat.tools.length, 0)}+</span>
          <span class="text-body-md text-mute">Tools Analyzed</span>
        </div>
        <div class="flex items-baseline gap-1.5">
