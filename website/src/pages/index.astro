---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import CategoryCard from '../components/CategoryCard.astro';
import ToolCard from '../components/ToolCard.astro';
import FAQSection from '../components/FAQSection.astro';
import Footer from '../components/Footer.astro';
import { categories, slugify } from '../data/tools';

const allCategories = [...categories].sort((a, b) => a.title.localeCompare(b.title));
const firstCategory = allCategories[0];
const remainingCategories = allCategories.slice(1);
const siteUrl = 'https://bestfreeaifor.com';
const catKeywords = allCategories.map(c => `best free ai for ${c.title.toLowerCase()}`).join(', ');
const homeKeywords = `best free ai for, best free ai tools 2026, free ai tools, best ai tools, ai tool directory, compare ai tools, ${catKeywords}`;
---

<Layout
  title="Best Free AI For 2026 — Compare & Discover Top Free AI Tools"
  description="Find the best free AI for 2026. Compare best free AI video generators, best free AI image to video tools, best AI for coding 2026, best AI for business, best AI for writing essays, and more — all with honest, unbiased reviews."
  canonicalUrl={`${siteUrl}/`}
  keywords={homeKeywords}
  ogImage={`${siteUrl}/og-image.png`}
  ogImageAlt="Best Free AI For 2026 — Compare top free AI tools including video generators, coding assistants, image generators, and writing tools"
>
  <Navbar />
  <Hero />

  <!-- Categories Section -->
  <section id="categories" class="py-16 md:py-24 scroll-mt-20">
    <div class="container-main">
      <div class="text-center mb-12">
        <span class="text-caption-mono text-mute block mb-3">CHOOSE YOUR NEED</span>
        <h2 class="text-display-lg text-ink mb-4 text-balance">What do you need AI for?</h2>
        <p class="text-body-lg text-body mx-auto text-balance">
          Select a category to discover the best free AI tools of 2026 — with honest comparisons and clear verdicts.
        </p>
      </div>

      <!-- Category Grid -->
      <div class="flex flex-col lg:flex-row gap-4 mb-16">
        <!-- Left Sidebar: Trends + News -->
        <div class="w-full lg:w-64 shrink-0 flex flex-col gap-4 lg:sticky lg:top-24 lg:z-10 order-3 lg:order-none">
          <div class="bg-canvas border border-hairline rounded-lg p-4">
            <span class="text-caption-mono text-mute block mb-3">AI TRENDS</span>
            <ul class="space-y-2.5">
              <li><a href="https://huggingface.co/papers" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">Hugging Face Papers</a></li>
              <li><a href="https://paperswithcode.com" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">Papers With Code</a></li>
              <li><a href="https://llm-stats.com/llm-updates" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">LLM Stats (Model Releases)</a></li>
              <li><a href="https://www.artificialintelligence-news.com" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">AI News</a></li>
              <li><a href="https://simonwillison.net/tags/ai/" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">Simon Willison AI</a></li>
              <li><a href="https://www.latent.space" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">Latent Space</a></li>
              <li><a href="https://www.theregister.com/software/ai/" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">The Register AI</a></li>
            </ul>
          </div>
          <div class="bg-canvas border border-hairline rounded-lg p-4">
            <span class="text-caption-mono text-mute block mb-3">AI NEWS</span>
            <ul class="space-y-2.5">
              <li><a href="https://openai.com/blog" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">OpenAI Blog (GPT-5.5, GPT Image 2)</a></li>
              <li><a href="https://www.anthropic.com/blog" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">Anthropic Blog (Claude Opus 4.8)</a></li>
              <li><a href="https://blog.google/technology/ai/" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">Google AI Blog (Gemini 3.5, Gemma 4)</a></li>
              <li><a href="https://microsoft.ai/news/" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">Microsoft AI (MAI Models)</a></li>
              <li><a href="https://techcrunch.com/category/artificial-intelligence/" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">TechCrunch AI</a></li>
              <li><a href="https://venturebeat.com/category/ai/" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">VentureBeat AI</a></li>
              <li><a href="https://www.technologyreview.com/topic/artificial-intelligence/" target="_blank" rel="noopener noreferrer" class="text-body-sm text-body no-underline hover:text-ink transition-colors">MIT Tech Review AI</a></li>
