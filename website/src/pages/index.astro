            <div class="flex flex-col gap-2.5">
              <a href="/offers/mythic" class="relative block rounded-lg p-3.5 no-underline overflow-hidden group shine-card rainbow-card shine-border">
                <div class="shine-overlay"></div>
                <div class="relative z-10">
                  <span class="text-xs font-bold tracking-widest text-black drop-shadow-lg uppercase">Mythic</span>
