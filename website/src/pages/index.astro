      #ffff00 28.57%, #ffff00 42.85%,
      #00cc44 42.85%, #00cc44 57.14%,
      #0088ff 57.14%, #0088ff 71.42%,
      #4400cc 71.42%, #4400cc 85.71%,
      #8800aa 85.71%, #8800aa 100%
    );
  }

  .purple-card {
    background: linear-gradient(to right,
      #e9d5ff 0%, #e9d5ff 20%,
      #d8b4fe 20%, #d8b4fe 40%,
      #a855f7 40%, #a855f7 60%,
      #7c3aed 60%, #7c3aed 80%,
      #581c87 80%, #581c87 100%
    );
  }

  .shine-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 0%,
      transparent 25%,
      rgba(192, 192, 192, 0.2) 35%,
      rgba(220, 220, 220, 0.45) 42%,
      rgba(240, 240, 240, 0.55) 48%,
      rgba(255, 255, 255, 0.6) 50%,
      rgba(240, 240, 240, 0.55) 52%,
      rgba(220, 220, 220, 0.45) 58%,
      rgba(192, 192, 192, 0.2) 65%,
      transparent 75%,
      transparent 100%
    );
    background-size: 400% 100%;
    animation: shineSweep 3s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes shineSweep {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .shine-border {
