---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const siteUrl = 'https://bestfreeaifor.com';
const contactBreadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Contact Us', url: `${siteUrl}/contact/` },
];
---

<Layout title="Contact Us — BestFreeAIFor" description="Contact BestFreeAIFor.com. Get in touch with questions, suggestions, or feedback about our free AI tool directory." canonicalUrl={`${siteUrl}/contact/`} keywords="best free ai for contact, bestfreeaifor contact, ai tool directory feedback, suggest ai tool" breadcrumbs={contactBreadcrumbs}>
  <Navbar />
  <main class="min-h-screen">
    <div class="container-main py-12">
      <nav class="flex items-center gap-2 text-body-sm text-mute mb-8">
        <a href="/" class="no-underline text-mute hover:text-ink transition-colors">Home</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-ink">Contact Us</span>
      </nav>

      <div class="text-center mb-12">
        <span class="text-caption-mono text-mute block mb-3">CONTACT</span>
        <h1 class="text-display-xl text-ink mb-4">Get in Touch</h1>
        <p class="text-body-lg text-body mx-auto text-balance">Have a question, suggestion, or feedback? We'd love to hear from you.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
        <div class="bg-canvas rounded-xl border border-hairline p-8 shadow-card">
          <h2 class="text-display-sm text-ink mb-6">Send us a Message</h2>
          <div class="space-y-4">
            <div>
              <label class="block text-body-sm text-ink mb-1">Name *</label>
              <input type="text" id="contact-name" class="w-full px-4 py-2.5 rounded-lg border border-hairline bg-canvas-soft text-ink focus:outline-none focus:border-ink transition-colors" placeholder="Your name" required />
            </div>
            <div>
              <label class="block text-body-sm text-ink mb-1">Email *</label>
              <input type="email" id="contact-email" class="w-full px-4 py-2.5 rounded-lg border border-hairline bg-canvas-soft text-ink focus:outline-none focus:border-ink transition-colors" placeholder="you@example.com" required />
            </div>
            <div>
              <label class="block text-body-sm text-ink mb-1">Message *</label>
              <textarea id="contact-message" class="w-full px-4 py-2.5 rounded-lg border border-hairline bg-canvas-soft text-ink focus:outline-none focus:border-ink transition-colors min-h-[120px]" placeholder="What's on your mind?" required></textarea>
            </div>
            <div id="contact-success" class="hidden bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-400 rounded-lg p-3 text-body-sm"></div>
            <div id="contact-error" class="hidden bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 rounded-lg p-3 text-body-sm"></div>
            <button id="contact-submit" class="w-full bg-ink text-white dark:text-canvas font-semibold py-2.5 px-4 rounded-lg hover:opacity-90 transition-opacity disabled:opacity-50 cursor-pointer">
              Send Message
            </button>
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-canvas rounded-xl border border-hairline p-6 shadow-card">
            <div class="w-10 h-10 rounded-lg bg-ink text-white dark:text-canvas flex items-center justify-center mb-4">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <h2 class="text-display-sm text-ink mb-2">Email Us</h2>
            <p class="text-body-md text-body mb-1">Prefer direct email? Write to us:</p>
            <a href="mailto:devpanks@gmail.com" class="text-body-md text-ink underline break-all">devpanks@gmail.com</a>
          </div>
          <div class="bg-canvas rounded-xl border border-hairline p-6 shadow-card">
            <div class="w-10 h-10 rounded-lg bg-ink text-white dark:text-canvas flex items-center justify-center mb-4">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h2 class="text-display-sm text-ink mb-2">Report an Issue</h2>
            <p class="text-body-md text-body mb-1">Found outdated info?</p>
            <a href="/submit" class="text-body-md text-ink underline">Submit a correction</a>
          </div>
          <div class="bg-canvas rounded-xl border border-hairline p-6 shadow-card">
            <div class="w-10 h-10 rounded-lg bg-ink text-white dark:text-canvas flex items-center justify-center mb-4">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h2 class="text-display-sm text-ink mb-2">Suggest a Tool</h2>
            <p class="text-body-md text-body mb-1">Know a great free AI tool?</p>
            <a href="/submit" class="text-body-md text-ink underline">Submit it here</a>
          </div>
        </div>
      </div>

      <div class="bg-canvas-soft rounded-xl border border-hairline p-8 text-center">
        <h2 class="text-display-sm text-ink mb-3">We Value Your Feedback</h2>
        <p class="text-body-md text-body">Every message is read and appreciated. We typically respond within 48 hours.</p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
import { api } from '../lib/api';

document.getElementById('contact-submit')?.addEventListener('click', async () => {
  const name = (document.getElementById('contact-name') as HTMLInputElement).value;
  const email = (document.getElementById('contact-email') as HTMLInputElement).value;
  const message = (document.getElementById('contact-message') as HTMLTextAreaElement).value;
  const errorEl = document.getElementById('contact-error')!;
  const successEl = document.getElementById('contact-success')!;
  const btn = document.getElementById('contact-submit') as HTMLButtonElement;

  errorEl.classList.add('hidden');
  successEl.classList.add('hidden');
  if (!name || !email || !message) { errorEl.textContent = 'All fields are required'; errorEl.classList.remove('hidden'); return; }

  btn.disabled = true; btn.textContent = 'Sending...';
  try {
    await api.contact({ name, email, message });
    successEl.textContent = 'Message sent! We\'ll get back to you soon.';
    successEl.classList.remove('hidden');
    (document.getElementById('contact-name') as HTMLInputElement).value = '';
    (document.getElementById('contact-email') as HTMLInputElement).value = '';
    (document.getElementById('contact-message') as HTMLTextAreaElement).value = '';
    btn.textContent = 'Sent!';
  } catch (err: any) {
    errorEl.textContent = err.message || 'Failed to send';
    errorEl.classList.remove('hidden');
    btn.disabled = false; btn.textContent = 'Send Message';
  }
});
</script>
