---
export interface Props {
  id: string;
  title: string;
  description: string;
  icon: string;
}

const { id, title, description, icon } = Astro.props;
---

<a
  href={`/category/${id}`}
  class="group flex items-start gap-2 p-3 rounded-lg border text-left no-underline transition-all duration-200 bg-canvas border-hairline hover:border-hairline-strong hover:shadow-card"
>
  <span class="text-lg mt-0.5 shrink-0">{icon}</span>
  <div class="min-w-0">
    <h3 class="text-body-sm text-ink font-medium mb-0.5">{title}</h3>
    <p class="text-body-sm text-body line-clamp-2">{description}</p>
  </div>
  <svg
    class="w-3 h-3 mt-1 shrink-0 text-mute opacity-0 group-hover:opacity-50 transition-opacity"
    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
  >
    <path d="M9 18l6-6-6-6"/>
  </svg>
</a>
