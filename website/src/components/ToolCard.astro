---
import type { Tool } from '../data/tools';

export interface Props {
  tool: Tool;
  rank: number;
  slug?: string;
}

const { tool, rank, slug } = Astro.props;
---

<div
  class="bg-canvas rounded-lg border border-hairline p-6 shadow-card hover:shadow-card-hover transition-shadow duration-200"
  data-aos="fade-up"
>
  <div class="flex items-start justify-between mb-4">
    <div class="flex items-center gap-3">
      <span class="flex items-center justify-center w-8 h-8 rounded-full bg-ink text-white dark:text-canvas text-caption-mono font-bold">
        {rank}
      </span>
      <div>
        {slug ? (
          <a href={`/tool/${slug}`} class="no-underline hover:underline">
            <h3 class="text-display-sm text-ink">{tool.name}</h3>
          </a>
        ) : (
          <h3 class="text-display-sm text-ink">{tool.name}</h3>
        )}
        <p class="text-caption-mono text-mute mt-0.5">{tool.bestFor}</p>
      </div>
    </div>
    <a
      href={tool.url}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-1 px-3 py-1 rounded-pill-sm text-body-sm text-ink border border-hairline no-underline hover:bg-canvas-soft-2 transition-colors"
    >
      Visit
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 21 3"/></svg>
    </a>
  </div>

  <p class="text-body-md text-body mb-5 leading-relaxed">{tool.description}</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
    <div class="p-4 rounded-md bg-canvas-soft border border-hairline">
      <div class="flex items-center gap-1.5 mb-2">
        <span class="w-3 h-3 rounded-full bg-success shrink-0"></span>
        <span class="text-body-sm-strong text-ink">Free Tier</span>
      </div>
      <p class="text-body-sm text-body">{tool.freeTier}</p>
    </div>

    <div class="p-4 rounded-md bg-canvas-soft border border-hairline">
      <div class="flex items-center gap-1.5 mb-2">
        <span class="w-3 h-3 rounded-full bg-warning shrink-0"></span>
        <span class="text-body-sm-strong text-ink">Paid Alternative</span>
      </div>
      <p class="text-body-sm text-body">
        {tool.paidTier ?? "No paid tier needed — completely free and open source."}
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
    <div>
      <span class="text-body-sm-strong text-ink mb-2 block">Pros</span>
      <ul class="space-y-1.5">
        {tool.pros.map((pro) => (
          <li class="flex items-start gap-2 text-body-sm text-body">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            {pro}
          </li>
        ))}
      </ul>
    </div>
    <div>
      <span class="text-body-sm-strong text-ink mb-2 block">Cons</span>
      <ul class="space-y-1.5">
        {tool.cons.map((con) => (
          <li class="flex items-start gap-2 text-body-sm text-body">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-error" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            {con}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="pt-4 border-t border-hairline">
    <div class="flex items-start gap-3">
      <svg class="w-5 h-5 mt-0.5 shrink-0 text-violet" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      <div>
        <span class="text-body-sm-strong text-ink block mb-0.5">Verdict</span>
        <p class="text-body-sm text-body">{tool.verdict}</p>
      </div>
    </div>
  </div>
</div>
